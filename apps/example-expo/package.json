{
  "main": "expo-router/entry",
  "name": "example-expo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "expo prebuild --clean",
    "start": "expo start",
    "ete:disable": "pnpm uninstall react-native-edge-to-edge || true",
    "ete:enable": "expo install react-native-edge-to-edge",
    "android": "expo run:android",
    "android:clean": "rm -rf .expo && rm -rf android && pnpm android",
    "ios": "expo run:ios",
    "ios:clean": "rm -rf .expo && rm -rf ios && pnpm ios",
    "reset-project": "node ./scripts/reset-project.js",
    "typecheck": "tsc",
    "lint": "expo lint && eslint",
    "format": "prettier",
    "check": "pnpm typecheck && prettier --write . && expo lint --fix && eslint --fix",
    "epc": "tsx scripts/expo-packages-check.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~53.0.27",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-embedded-stack-navigator": "workspace:*",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-the-sheet": "workspace:*",
    "react-native-universe-portal": "workspace:*",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@react-native/eslint-config": "^0.85.1",
    "@types/node": "^25.6.0",
    "@types/react": "~19.0.14",
    "@types/semver": "^7.7.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "semver": "^7.7.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  }
}
